# Params for .github/workflows/survivorship_shards.yml.
# Editing this file (or the workflow) is what triggers a run on this branch,
# so the periodic sims_full/ checkpoint auto-commits never re-launch the matrix.
# FULL RUN: 8 parallel shards, no ticker cap, collect+commit the verdict.
NUM_SHARDS=8
LIMIT=
DO_COLLECT=true
